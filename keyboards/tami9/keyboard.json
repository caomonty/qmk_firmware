{
    "keyboard_name": "Tami9",
    "manufacturer": "Carlos Mondragon",
    "maintainer": "carlos",
    "processor": "RP2040",
    "bootloader": "rp2040",
    "url": "https://github.com/your-repo/tami9",
    "diode_direction": "COL2ROW",
    "matrix_pins": {
      "cols": ["GP2", "GP3", "GP4"],
      "rows": ["GP6", "GP7", "GP8"]
    },
    "usb": {
      "vid": "0xCAFE",
      "pid": "0x6001",
      "device_version": "1.0.0"
    },
    "features": {
      "bootmagic": true,
      "command": false,
      "console": true,
      "extrakey": true,
      "mousekey": false,
      "nkro": true
    },
    "layouts": {
      "LAYOUT": {
        "layout": [
          { "matrix": [0, 0], "x": 0, "y": 0 },
          { "matrix": [0, 1], "x": 1, "y": 0 },
          { "matrix": [0, 2], "x": 2, "y": 0 },
          { "matrix": [1, 0], "x": 0, "y": 1 },
          { "matrix": [1, 1], "x": 1, "y": 1 },
          { "matrix": [1, 2], "x": 2, "y": 1 },
          { "matrix": [2, 0], "x": 0, "y": 2 },
          { "matrix": [2, 1], "x": 1, "y": 2 },
          { "matrix": [2, 2], "x": 2, "y": 2 }
        ]
      }
    }
  }
